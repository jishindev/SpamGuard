<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme. -->
    <style name="Theme.SpamGuard" parent="Theme.MaterialComponents.Light.NoActionBar">

        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/white</item>
        <item name="colorPrimaryVariant">@color/white</item>
        <item name="colorOnPrimary">@color/dk_grey</item>
        <item name="colorAccent">@color/teal_700</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>

        <item name="bottomSheetDialogTheme">@style/BSDialogTheme</item>

        <item name="fontFamily">@font/roboto</item>
    </style>

    <style name="BSDialogTheme" parent="Theme.MaterialComponents.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/BSDialogStyle</item>
        <item name="colorPrimary">@color/md_grey</item>
        <item name="colorOnPrimary">@color/dk_grey</item>
        <item name="colorOnSurface">@color/dk_grey</item>
        <item name="fontFamily">@font/roboto</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowSoftInputMode">adjustResize</item>
    </style>

    <style name="BSDialogStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@drawable/bg_rounded_white</item>
    </style>
</resources>